generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ------------------------------------------------------
// 1. NextAuth / User Profile / Gamification Models
// ------------------------------------------------------

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  password      String? 
  
  // Gamification & Progress
  xp            Int       @default(0)
  coins         Int       @default(0)
  streak        Int       @default(0)
  lastLogin     DateTime? @default(now())

  accounts      Account[]
  sessions      Session[]
  progress      UserProgress[]
}

model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?  @db.Text
  access_token       String?  @db.Text
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?  @db.Text
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ------------------------------------------------------
// 2. Core App Logic (Dictionary, Content, MVP Lessons)
// ------------------------------------------------------

model Word {
  id              String   @id @default(cuid())
  word            String   @unique
  definition      String   @db.Text
  partOfSpeech    String?
  difficultyLevel Int      @default(1) // 1 = Easy (Frequent), 3 = Hard (Rare)

  lessons         LessonWord[]
  content         Content[]
  userProgress    UserProgress[]
}

model Content {
  id            String   @id @default(cuid())
  wordId        String
  contentType   String   // 'example_formal', 'example_casual', 'quiz_fill_blank'
  textBody      String   @db.Text
  options       Json?    // Stores multiple choice array if contentType is quiz
  correctAnswer String?  // Stores correct index or string

  word          Word     @relation(fields: [wordId], references: [id], onDelete: Cascade)
}

model Lesson {
  id           String   @id @default(cuid())
  lessonNumber Int      @unique
  title        String
  
  words        LessonWord[]
}

model LessonWord {
  lessonId String
  wordId   String

  lesson   Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  word     Word   @relation(fields: [wordId], references: [id], onDelete: Cascade)

  @@id([lessonId, wordId])
}

// ------------------------------------------------------
// 3. Spaced Repetition Tracker (SuperMemo-2 data)
// ------------------------------------------------------

model UserProgress {
  id              String   @id @default(cuid())
  userId          String
  wordId          String
  status          String   @default("learning") // 'learning', 'reviewing', 'mastered'
  
  // SRS Algorithm fields
  easeFactor      Float    @default(2.5) // Standard starting multiplier for SM-2
  interval        Int      @default(0)   // Days until next review
  nextReviewDate  DateTime @default(now())

  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  word            Word     @relation(fields: [wordId], references: [id], onDelete: Cascade)

  @@unique([userId, wordId])
}